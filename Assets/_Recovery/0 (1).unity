  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "MENTAL HEALTH IN AFRICA\n\n- 116 million Africans live with \n  a mental
    health condition\n\n- Only 1.4% of Africa's health \n  budget goes to mental
    health\n\n- There is 1 psychiatrist for every \n  500,000 people in Africa\n\n-
    Uganda has only 47 psychiatrists \n  for 45 million people\n\nRegional integration
    can help share \nresources across African nations."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: dc36b3fdc14f47ebb36fd484a67e268a, type: 2}
  m_sharedMaterial: {fileID: 2140032, guid: dc36b3fdc14f47ebb36fd484a67e268a, type: 2}
