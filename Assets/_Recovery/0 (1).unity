  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'WHAT IS MENTAL HEALTH?


    Mental health includes our emotional,

    psychological
    and social well-being.


    It affects how we think, feel and act

    in our
    daily lives.


    1 in 4 people in Africa will experience

    a mental health
    condition in their lifetime.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
